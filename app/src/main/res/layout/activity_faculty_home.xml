<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FacultyHomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <!-- Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:fitsSystemWindows="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/bottomNavFaculty">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <!-- Dynamic Header Section -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Gradient Background with Rounded Bottom -->
                    <View
                        android:id="@+id/headerBg"
                        android:layout_width="match_parent"
                        android:layout_height="320dp"
                        android:background="@drawable/bg_gradient_faculty_header"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Toolbar Actions -->
                    <ImageButton
                        android:id="@+id/btnMenu"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#20FFFFFF"
                        android:src="@drawable/ic_menu"
                        android:padding="12dp"
                        app:tint="#FFFFFF"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvAppTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RANKUP\nFACULTY"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/btnMenu"
                        app:layout_constraintBottom_toBottomOf="@+id/btnMenu"/>

                    <ImageButton
                        android:id="@+id/btnNotification"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#20FFFFFF"
                        android:src="@drawable/ic_notification"
                        android:padding="12dp"
                        app:tint="#FFFFFF"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Profile Section -->
                     <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="40dp"
                        android:src="@drawable/ic_profile"
                        android:background="@drawable/bg_card_white"
                        android:padding="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/btnMenu" />

                     <ImageView
                         android:layout_width="20dp"
                         android:layout_height="20dp"
                         android:src="@drawable/ic_check_circle_green"
                         app:layout_constraintBottom_toBottomOf="@+id/imgProfile"
                         app:layout_constraintEnd_toEndOf="@+id/imgProfile"/>

                     <TextView
                         android:id="@+id/tvRole"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:text="CHIEF ACADEMIC OFFICER"
                         android:textColor="#CCFFFFFF"
                         android:textSize="8sp"
                         android:textStyle="bold"
                         android:letterSpacing="0.1"
                         android:layout_marginStart="16dp"
                         app:layout_constraintStart_toEndOf="@+id/imgProfile"
                         app:layout_constraintTop_toTopOf="@+id/imgProfile"/>

                     <TextView
                         android:id="@+id/tvName"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:text="Prof. Rajesh\nKumar"
                         android:textColor="#FFFFFF"
                         android:textSize="24sp"
                         android:textStyle="bold"
                         android:fontFamily="sans-serif-black"
                         android:layout_marginStart="16dp"
                         android:layout_marginEnd="24dp"
                         android:layout_marginTop="4dp"
                         app:layout_constraintStart_toEndOf="@+id/imgProfile"
                         app:layout_constraintTop_toBottomOf="@+id/tvRole"
                         app:layout_constraintEnd_toEndOf="parent"/>

                     <LinearLayout
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:layout_marginTop="8dp"
                         android:layout_marginStart="16dp"
                         app:layout_constraintStart_toEndOf="@+id/imgProfile"
                         app:layout_constraintTop_toBottomOf="@+id/tvName">
                         
                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:id="@+id/tvFacultyDept"
                             android:text="DEPT OF COMP SCIENCE"
                             android:textColor="#FFFFFF"
                             android:textSize="8sp"
                             android:textStyle="bold"
                             android:background="@drawable/bg_chip_blue"
                             android:backgroundTint="#40FFFFFF"
                             android:paddingHorizontal="8dp"
                             android:paddingVertical="4dp"/>

                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="VERIFIED HOD"
                             android:textColor="#FFFFFF"
                             android:textSize="8sp"
                             android:textStyle="bold"
                             android:background="@drawable/bg_chip_blue"
                             android:backgroundTint="#00C853"
                             android:paddingHorizontal="8dp"
                             android:paddingVertical="4dp"
                             android:layout_marginStart="8dp"/>
                     </LinearLayout>

                    <!-- Stats Row (Floating below header curve) -->
                     <androidx.cardview.widget.CardView
                         android:id="@+id/cardStats"
                         android:layout_width="match_parent"
                         android:layout_height="80dp"
                         android:layout_marginHorizontal="24dp"
                         android:layout_marginTop="24dp"
                         app:cardCornerRadius="20dp"
                         app:cardElevation="8dp"
                         app:cardBackgroundColor="#FFFFFF"
                         app:layout_constraintTop_toBottomOf="@+id/imgProfile"
                         app:layout_constraintBottom_toBottomOf="@+id/headerBg">
                         
                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="match_parent"
                             android:orientation="horizontal"
                             android:gravity="center">
                             
                             <!-- Stat 1 -->
                             <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                 <TextView
                                     android:id="@+id/tvClassesCount"
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="--"
                                     android:textColor="#304FFE"
                                     android:textSize="18sp"
                                     android:textStyle="bold"/>
                                 <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CLASSES" android:textColor="#9E9E9E" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                             </LinearLayout>

                             <View android:layout_width="1dp" android:layout_height="40dp" android:background="#EEEEEE"/>

                             <!-- Stat 2 -->
                             <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                 <TextView
                                     android:id="@+id/tvActiveTestsCount"
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="--"
                                     android:textColor="#00C853"
                                     android:textSize="18sp"
                                     android:textStyle="bold"/>
                                 <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACTIVE TESTS" android:textColor="#9E9E9E" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                             </LinearLayout>

                             <View android:layout_width="1dp" android:layout_height="40dp" android:background="#EEEEEE"/>

                             <!-- Stat 3 -->
                             <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                 <TextView
                                     android:id="@+id/tvSubmissionsCount"
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="--"
                                     android:textColor="#6200EA"
                                     android:textSize="18sp"
                                     android:textStyle="bold"/>
                                 <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SUBMISSIONS" android:textColor="#9E9E9E" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                             </LinearLayout>
                         </LinearLayout>
                     </androidx.cardview.widget.CardView>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Dashboard Content -->
                <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="MASTER CONTROL REGISTER"
                     android:textColor="#BDBDBD"
                     android:textSize="10sp"
                     android:textStyle="bold"
                     android:letterSpacing="0.1"
                     android:layout_marginStart="24dp"
                     android:layout_marginTop="24dp"/>

                <!-- Academic Forge Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAcademic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_academic_forge"
                        android:padding="24dp">
                        
                        <ImageView
                            android:id="@+id/imgAcadIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_resume"
                            android:background="@drawable/bg_circle_translucent"
                            android:backgroundTint="#20FFFFFF"
                            android:padding="10dp"
                            app:tint="#FFFFFF"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                         
                         <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_mentors"
                            android:alpha="0.1"
                            app:tint="#FFFFFF"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/tvAcadTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Academic Forge"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@+id/imgAcadIcon" 
                            app:layout_constraintStart_toStartOf="parent"/>
                            
                         <TextView
                            android:id="@+id/tvAcadSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GATE 2026 &amp; IELTS 2025 MANAGEMENT"
                            android:textColor="#CCFFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="4dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvAcadTitle"
                            app:layout_constraintStart_toStartOf="parent"/>
                            
                        <!-- Progress Bar -->
                        <ProgressBar
                            android:id="@+id/progressAcad"
                            android:layout_width="120dp"
                            android:layout_height="6dp"
                            android:layout_marginTop="16dp"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progress="72"
                            android:progressTint="#00E676"
                            android:progressBackgroundTint="#40FFFFFF"
                            app:layout_constraintTop_toBottomOf="@+id/tvAcadSub"
                            app:layout_constraintStart_toStartOf="parent"/>
                            
                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvSyllabusProgress"
                            android:text="72% SYLLABUS COMPLETE"
                            android:textColor="#00E676"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp"
                            app:layout_constraintStart_toEndOf="@+id/progressAcad"
                            app:layout_constraintBottom_toBottomOf="@+id/progressAcad"
                            app:layout_constraintTop_toTopOf="@+id/progressAcad"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- Placement Hub Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFacultyPlacement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_placement_hub"
                        android:padding="24dp">
                        
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_target"
                            android:background="@drawable/bg_circle_translucent"
                            android:backgroundTint="#20FFFFFF"
                            android:padding="10dp"
                            app:tint="#FFFFFF"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <ImageView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/ic_bolt"
                            android:alpha="0.05"
                            android:rotation="15"
                            app:tint="#FFD600"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/tvPlaceTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Placement Hub"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginTop="56dp" 
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvPlaceSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INDUSTRY ROCK\nDEPLOYMENT &amp; CODING"
                            android:textColor="#9E9E9E"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="8dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvPlaceTitle"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <!-- Action Buttons -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE TESTS"
                            android:textColor="#1A1A2E"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_chip_blue"
                            android:backgroundTint="#FFD600"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvPlaceSub"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPCOMING DRIVES"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_chip_blue"
                            android:backgroundTint="#304FFE"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginStart="8dp"
                            app:layout_constraintStart_toEndOf="@+id/tvPlaceSub" 
                            app:layout_constraintTop_toBottomOf="@+id/tvPlaceSub"
                            app:layout_constraintBaseline_toBaselineOf="@+id/tvPlaceSub" /> 

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- Inventory Ingestion (Tools) -->
                <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="INVENTORY INGESTION"
                     android:textColor="#BDBDBD"
                     android:textSize="10sp"
                     android:textStyle="bold"
                     android:letterSpacing="0.1"
                     android:layout_marginStart="24dp"
                     android:layout_marginTop="24dp"/>

                <!-- Company Questions Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnCompanyQues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_code"
                            android:background="@drawable/bg_circle_translucent"
                            android:backgroundTint="#E3F2FD"
                            android:padding="12dp"
                            app:tint="#1565C0"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COMPANY QUESTIONS" android:textStyle="bold" android:textColor="#0D1B2A"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ADD CODING CHALLENGES" android:textStyle="bold" android:textSize="8sp" android:textColor="#9E9E9E"/>
                        </LinearLayout>
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_arrow_forward" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#F5F5F5" android:padding="8dp" app:tint="#BDBDBD"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

    <!-- Resources Button (Formerly MCQ Matrix) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_folder" 
                android:background="@drawable/bg_circle_translucent"
                android:backgroundTint="#E3F2FD"
                android:padding="8dp"
                app:tint="#304FFE"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESOURCES"
                android:textColor="#0D1B2A"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPLOAD &amp; MANAGE\nCONTENT"
                android:textColor="#9E9E9E"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

                <!-- List Items -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardResumeReview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                         <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_resume"
                            android:background="@drawable/bg_circle_translucent"
                            android:backgroundTint="#FFEBEE"
                            android:padding="12dp"
                            app:tint="#D32F2F"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESUME REVIEW" android:textStyle="bold" android:textColor="#0D1B2A"/>
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STUDENT PROFILES" android:textStyle="bold" android:textSize="8sp" android:textColor="#9E9E9E"/>
                        </LinearLayout>
                         <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_arrow_forward" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#F5F5F5" android:padding="8dp" app:tint="#BDBDBD"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardJoinRequests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                         <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_mentors"
                            android:background="@drawable/bg_circle_translucent"
                            android:backgroundTint="#F3E5F5"
                            android:padding="12dp"
                            app:tint="#7B1FA2"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="JOIN REQUESTS" android:textStyle="bold" android:textColor="#0D1B2A"/>
                             <TextView 
                                 android:id="@+id/tvJoinRequestsCount"
                                 android:layout_width="wrap_content" 
                                 android:layout_height="wrap_content" 
                                 android:text="12 CANDIDATES AWAITING VERIFICATION" 
                                 android:textStyle="bold" android:textSize="8sp" android:textColor="#9E9E9E"/>
                        </LinearLayout>
                         <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_arrow_forward" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#F5F5F5" android:padding="8dp" app:tint="#BDBDBD"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Schedule Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_schedule"
                        android:padding="24dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="24dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_briefcase" app:tint="#FFFFFF"/> <!-- Calendar Icon substitute -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STRATEGIC SCHEDULE" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp" android:layout_marginStart="12dp"/>
                        </LinearLayout>

                        <!-- Schedule Item 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GATE MOCK 04" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOMORROW, 09:00" android:textColor="#BDBDBD" android:textSize="10sp"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EXAM" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:background="@drawable/bg_chip_blue" android:backgroundTint="#20FFFFFF" android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
                        </LinearLayout>

                         <!-- Schedule Item 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DSA RENDEZVOUS" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FRI, 14:00" android:textColor="#BDBDBD" android:textSize="10sp"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SESSION" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:background="@drawable/bg_chip_blue" android:backgroundTint="#20FFFFFF" android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
                        </LinearLayout>
                        
                         <!-- Schedule Item 3 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ALGO WRITING QA" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MON, 11:30" android:textColor="#BDBDBD" android:textSize="10sp"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GRADING" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:background="@drawable/bg_chip_blue" android:backgroundTint="#20FFFFFF" android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavFaculty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:menu="@menu/menu_faculty_bottom_nav"
            app:itemIconTint="@drawable/selector_bottom_nav"
            app:itemTextColor="@drawable/selector_bottom_nav"
            app:labelVisibilityMode="labeled"
            app:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navViewFaculty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        app:headerLayout="@layout/nav_header_faculty"
        app:menu="@menu/menu_faculty_drawer">
        
        <include
            layout="@layout/layout_faculty_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"/>

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
