<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StudentHomeActivity">

    <!-- Main Layout Container (Content + Bottom Nav) -->
    <!-- Main Layout Container (Content + Bottom Nav) -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F9FA"
            android:fillViewport="true"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:fitsSystemWindows="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="42dp">

                <!-- Header -->
                <View
                    android:id="@+id/headerBg"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="#1C52E6"
                    app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RANKUP"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-black"
            android:layout_marginTop="26dp"
            app:layout_constraintStart_toEndOf="@+id/btnMenu"
            app:layout_constraintEnd_toStartOf="@+id/btnNotification"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_notification"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Welcome Text (Inside Blue Header) -->
        <TextView
            android:id="@+id/tvWelcomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="WELCOME BACK,"
            android:textColor="#B3FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnMenu" />

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="User Name"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvWelcomeLabel" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvUserName">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="CSE - 3rd Year"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="PLACEMENT TRACK"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Briefcase Icon (Transparent Overlay) -->
         <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_briefcase"
            android:alpha="0.1"
            android:layout_marginEnd="-20dp"
            android:layout_marginTop="40dp"
            app:tint="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!-- Grid Menu (Mentors & Rankings) -->
        <LinearLayout
            android:id="@+id/layoutGridMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="-40dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@+id/headerBg">

            <!-- Mentors Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMentors"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_mentors"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mentors"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REQUEST GUIDANCE"
                        android:textColor="#9E9E9E"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Rankings Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRankings"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_rankings"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#FFF3E0"
                        android:padding="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rankings"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GLOBAL STANDINGS"
                        android:textColor="#9E9E9E"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Resume Builder Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResume"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@+id/layoutGridMenu">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_resume"
                    android:background="@drawable/bg_circle_translucent"
                    android:backgroundTint="#F3E5F5"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resume Builder"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREATE &amp; EXPORT PROFESSIONAL CVs"
                        android:textColor="#9E9E9E"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="#BDBDBD"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

<!-- Central Score Card Removed per User Request -->

        <!-- Roadmap Title -->
        <TextView
            android:id="@+id/tvRoadmapTitle"
             android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLACEMENT ROADMAP"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardResume" />

        <TextView
             android:layout_width="wrap_content"
            android:layout_height="wrap_content"
             android:text="ACTIVE"
             android:textColor="#1C52E6"
             android:textSize="10sp"
             android:textStyle="bold"
             android:letterSpacing="0.1"
             android:background="@drawable/bg_chip_blue"
             android:backgroundTint="#E3F2FD"
             android:paddingHorizontal="8dp"
             android:paddingVertical="2dp"
             android:layout_marginEnd="24dp"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintBaseline_toBaselineOf="@+id/tvRoadmapTitle"/>

        <!-- Phase 1 Card (Light Blue) -->
        <!-- [DELETED] Phase 1 Card (Aptitude) removed as per user request -->

        <!-- Phase 4 Card (Blue Gradient - Mock Tests) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPhase4"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@+id/tvRoadmapTitle">
             <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_card_blue_gradient"
                android:padding="24dp">

                 <ImageView
                     android:layout_width="48dp"
                     android:layout_height="48dp"
                     android:src="@drawable/ic_briefcase"
                     android:background="@drawable/bg_circle_translucent"
                     android:backgroundTint="#33FFFFFF"
                     android:padding="10dp"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toTopOf="parent"/>

                 <ImageView
                     android:layout_width="80dp"
                     android:layout_height="80dp"
                     android:src="@drawable/ic_bolt"
                     android:alpha="0.1"
                     android:rotation="15"
                     app:tint="#FFFFFF"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintTop_toTopOf="parent"/>

                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="Full Mock Tests"
                     android:textColor="#FFFFFF"
                     android:textSize="20sp"
                     android:textStyle="bold"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintBottom_toTopOf="@+id/tvPhase4Sub"/>

                 <TextView
                     android:id="@+id/tvPhase4Sub"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="PHASE 4: FULL PLACED TRACK"
                     android:textColor="#CCFFFFFF"
                     android:textSize="10sp"
                     android:textStyle="bold"
                     android:letterSpacing="0.05"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
        
        <!-- Technical & Coding Row -->
         <LinearLayout
            android:id="@+id/layoutGridPhases"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@+id/cardPhase4">

             <androidx.cardview.widget.CardView
                android:id="@+id/cardTechnical"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">
                     <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_brain"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#EDE7F6"
                        android:padding="6dp"/>
                     <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Technical"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CORE Q&amp;A"
                        android:textColor="#9E9E9E"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                 </LinearLayout>
             </androidx.cardview.widget.CardView>

             <androidx.cardview.widget.CardView
                android:id="@+id/cardCompanyQues"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">
                     <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_target"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"/>
                     <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Company"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MNC ARCHIVE"
                        android:textColor="#9E9E9E"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                 </LinearLayout>
             </androidx.cardview.widget.CardView>

             <androidx.cardview.widget.CardView
                android:id="@+id/cardCoding"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">
                     <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_code"
                        android:background="@drawable/bg_circle_translucent"
                        android:backgroundTint="#E0F2F1"
                        android:padding="6dp"/>
                     <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coding"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DSA DRILLS"
                        android:textColor="#9E9E9E"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                 </LinearLayout>
             </androidx.cardview.widget.CardView>
         </LinearLayout>


        <!-- Communication Round Card -->
         <androidx.cardview.widget.CardView
            android:id="@+id/cardCommunication"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@+id/layoutGridPhases">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_wave"
                    android:background="@drawable/bg_circle_translucent"
                    android:backgroundTint="#F3E5F5"
                    android:padding="10dp"
                    app:tint="#7B1FA2"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Communication Round"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHASE 5: HR &amp; SOFT SKILLS"
                        android:textColor="#9E9E9E"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <TextView
                     android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                     android:text="SOFT SKILLS"
                     android:textColor="#7B1FA2"
                     android:textSize="8sp"
                     android:textStyle="bold"
                     android:background="@drawable/bg_chip_blue"
                     android:backgroundTint="#F3E5F5"
                     android:paddingHorizontal="8dp"
                     android:paddingVertical="4dp"
                     android:layout_marginEnd="8dp"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="#BDBDBD"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Placement Analytics Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAnalytics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@+id/cardCommunication"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvAnalyticsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLACEMENT\nANALYTICS"
                    android:textColor="#0D1B2A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                     android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                     android:id="@+id/tvWeeklyGrowth"
                     android:text="+12% WEEKLY"
                     android:textColor="#00C853"
                     android:textSize="10sp"
                     android:textStyle="bold"
                     android:background="@drawable/bg_chip_blue"
                     android:backgroundTint="#E8F5E9"
                     android:paddingHorizontal="8dp"
                     android:paddingVertical="4dp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintTop_toTopOf="parent"/>

                <!-- Chart Bars Container -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="32dp"
                    app:layout_constraintTop_toBottomOf="@+id/tvAnalyticsTitle"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <!-- Bar 1: Mon -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="80dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <!-- Bar 2: Tue -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="100dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tue" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                     <!-- Bar 3: Wed -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="90dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wed" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                     <!-- Bar 4: Thu -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="120dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                     <!-- Bar 5: Fri -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="110dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fri" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                     <!-- Bar 6: Sat -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="140dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sat" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                     <!-- Bar 7: Sun -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="16dp" android:layout_height="130dp" android:background="@drawable/bg_bar_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sun" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@drawable/selector_nav_item_color"
        app:itemTextColor="@drawable/selector_nav_item_color"
        app:itemRippleColor="#331C52E6"
        app:labelVisibilityMode="labeled"
        android:elevation="8dp"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Container (Drawer Content) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:fitsSystemWindows="true">

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:headerLayout="@layout/nav_header_student"
            app:menu="@menu/activity_student_drawer_menu"
            app:itemIconTint="#0D1B2A"
            app:itemTextColor="#0D1B2A"
            app:itemHorizontalPadding="24dp"
            app:itemIconPadding="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/navFooter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <include layout="@layout/nav_footer_student"
            android:id="@+id/navFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.drawerlayout.widget.DrawerLayout>
