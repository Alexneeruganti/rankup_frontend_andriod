<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".TechnicalRoundActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1C52E6"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Technical Round"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Topic Selection -->
    <LinearLayout
        android:id="@+id/topicLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Topic:"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:layout_marginEnd="8dp"/>

        <Spinner
            android:id="@+id/spinnerTopic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:entries="@array/tech_topics_array"
            android:background="@drawable/bg_edit_text_simple"/>
            
        <Button
            android:id="@+id/btnStartTopic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="START"
            android:layout_marginStart="8dp"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- Question Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@+id/topicLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvQuestionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1/10"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Select a topic and click Start to begin."
                android:textColor="#0D1B2A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp"/>
            
            <!-- Answer Section (Using Toggle for "Show Answer" for simplicity, or RadioGroup) -->
            <!-- Requirement says "students select topic they need the questions and generate" -->
            <!-- Let's do a simple Show Answer approach for drill mode -->
            
            <Button
                android:id="@+id/btnShowAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SHOW ANSWER"
                android:layout_marginTop="24dp"
                android:backgroundTint="#FF6D00"/>

            <TextView
                android:id="@+id/tvAnswerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Answer will appear here."
                android:textColor="#00C853"
                android:textSize="16sp"
                android:visibility="gone"
                android:background="#E8F5E9"
                android:padding="12dp"/>
                
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnNextQuestion"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="NEXT QUESTION"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#1C52E6"
        android:layout_margin="16dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
