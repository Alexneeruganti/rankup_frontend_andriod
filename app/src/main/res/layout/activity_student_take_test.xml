<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/schemas/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".StudentTakeTestActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C52E6"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTestTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Taking Test..."
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvQuestionNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1 of 10"
                android:textColor="#1C52E6"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading Question..."
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <RadioGroup
                android:id="@+id/rgOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbOptionA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option A"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_option_state"
                    android:buttonTint="#1C52E6"/>

                <RadioButton
                    android:id="@+id/rbOptionB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option B"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_option_state"
                    android:buttonTint="#1C52E6"/>

                <RadioButton
                    android:id="@+id/rbOptionC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option C"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_option_state"
                    android:buttonTint="#1C52E6"/>

                <RadioButton
                    android:id="@+id/rbOptionD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option D"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_option_state"
                    android:buttonTint="#1C52E6"/>
            </RadioGroup>

            <!-- Embedded Coding Editor (Hidden by default) -->
            <LinearLayout
                android:id="@+id/llCodingEditor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvCodingConstraints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Constraints:"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginBottom="16dp"
                    android:background="#E8EAF6"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <Spinner
                        android:id="@+id/spinnerLanguage"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edit_text_rounded"
                        android:entries="@array/language_types"/>
                        
                    <Button
                        android:id="@+id/btnRunCode"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="COMPILE RUN"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#4CAF50"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="8dp"
                        app:icon="@drawable/ic_play"
                        app:iconPadding="0dp"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/etCodeEditor"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:background="#1E1E1E"
                    android:textColor="#A9B7C6"
                    android:textColorHint="#5E5E5E"
                    android:hint="// Write your code here..."
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TERMINAL CONSOLE"
                    android:textColor="#1C52E6"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvOutput"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#0D1B2A"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:text="Awaiting standard execution log..."
                    android:scrollbars="vertical"
                    android:gravity="top|start" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#1C52E6"
            android:padding="16dp"
            android:text="Next Question"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
