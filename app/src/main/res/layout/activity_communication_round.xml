<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".CommunicationRoundActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#6200EA"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Communication Round"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarRound"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progress="33"
        android:progressTint="#00C853"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@+id/progressBarRound"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvRoundTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUND 1: READING"
                android:textColor="#6200EA"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvRoundInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read the following passage carefully and answer the questions below."
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_marginTop="8dp"/>

            <!-- Content Area (Card) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <!-- Passage / Content -->
                    <TextView
                        android:id="@+id/tvPassage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading content..."
                        android:textColor="#0D1B2A"
                        android:textSize="16sp"
                        android:lineSpacingExtra="6dp"/>

                    <!-- Audio Player Control (For Listening Round) -->
                    <Button
                        android:id="@+id/btnPlayAudio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PLAY AUDIO"
                        android:layout_marginTop="16dp"
                        app:icon="@drawable/ic_volume_up"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Question Area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question:"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading question..."
                android:textColor="#000000"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Type your answer here..."
                android:background="@drawable/bg_edit_text_simple"
                android:padding="12dp"/>

            <Button
                android:id="@+id/btnSubmitAnswer"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SUBMIT"
                android:layout_marginTop="32dp"
                app:cornerRadius="12dp"
                android:backgroundTint="#6200EA"/>
            
             <TextView
                android:id="@+id/tvFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text=""
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="14sp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
