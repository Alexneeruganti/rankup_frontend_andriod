<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <!-- Header Section -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#2962FF"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:padding="12dp"
        app:tint="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Student Performance"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@+id/btnBack"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Track individual progress and analytics"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"/>

    <!-- Content ScrollView -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_bottom_sheet_rounded"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Search Bar -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_field"
                android:hint="Search by name or roll number..."
                android:textColor="#0D1B2A"
                android:textColorHint="#9E9E9E"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="12dp"
                android:layout_marginBottom="24dp"/>

            <!-- Class Average Performance -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class Average Performance"
                android:textColor="#0D1B2A"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <!-- Overall -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_analytics"
                    android:backgroundTint="#F5F5F5"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/tvOverallScore"
                        android:text="73%"
                        android:textColor="#2962FF"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OVERALL"
                        android:textColor="#2962FF"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Aptitude -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_analytics"
                    android:backgroundTint="#F5F5F5"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/tvAptitudeScoreHeader"
                        android:text="76%"
                        android:textColor="#00C853"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APTITUDE"
                        android:textColor="#00C853"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Coding -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_analytics"
                    android:backgroundTint="#F5F5F5"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/tvCodingScoreHeader"
                        android:text="68%"
                        android:textColor="#6200EA"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CODING"
                        android:textColor="#6200EA"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Progress Trend (Mock Graph) -->
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class Progress Trend"
                android:textColor="#0D1B2A"
                android:textStyle="bold"
                android:textSize="16sp"/>
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+12% vs last month"
                android:textColor="#2962FF"
                android:textSize="10sp"
                android:background="@drawable/bg_chip_blue"
                android:backgroundTint="#E3F2FD"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginBottom="16dp"/>
            
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F9FAFB">
                <!-- Mock Graph Visualization -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                     <!-- Axis Lines -->
                     <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_alignParentBottom="true" android:layout_marginBottom="30dp"/>
                     <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_alignParentBottom="true" android:layout_marginBottom="70dp"/>
                     <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_alignParentBottom="true" android:layout_marginBottom="110dp"/>
                     <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_alignParentBottom="true" android:layout_marginBottom="150dp"/>

                    <!-- Trend Line (Using a pre-made vector or constructing with Views is hard in XML only. Using simple points and connectors for "mock" effect) -->
                    <!-- Point 1 -->
                    <View android:id="@+id/p1" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#2962FF" android:layout_alignParentBottom="true" android:layout_marginBottom="100dp" android:layout_marginStart="40dp"/>
                    <!-- Point 2 -->
                    <View android:id="@+id/p2" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#2962FF" android:layout_alignParentBottom="true" android:layout_marginBottom="120dp" android:layout_marginStart="120dp"/>
                     <!-- Point 3 -->
                    <View android:id="@+id/p3" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#2962FF" android:layout_alignParentBottom="true" android:layout_marginBottom="115dp" android:layout_marginStart="200dp"/>
                     <!-- Point 4 -->
                    <View android:id="@+id/p4" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_circle_translucent" android:backgroundTint="#2962FF" android:layout_alignParentBottom="true" android:layout_marginBottom="145dp" android:layout_marginStart="280dp"/>
                    
                    <!-- Labels -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W1" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_alignParentBottom="true" android:layout_marginBottom="10dp" android:layout_marginStart="40dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W2" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_alignParentBottom="true" android:layout_marginBottom="10dp" android:layout_marginStart="120dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W3" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_alignParentBottom="true" android:layout_marginBottom="10dp" android:layout_marginStart="200dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W4" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_alignParentBottom="true" android:layout_marginBottom="10dp" android:layout_marginStart="280dp"/>
                    
                    <!-- Simple Lines visual hack (rotated views) -->
                    <!-- Line 1-2 -->
                    <View android:layout_width="86dp" android:layout_height="2dp" android:background="#2962FF" android:layout_alignStart="@+id/p1" android:layout_alignBottom="@+id/p1" android:layout_marginBottom="15dp" android:rotation="-12" android:transformPivotX="0dp"/>
                    <!-- Line 2-3 -->
                    <View android:layout_width="86dp" android:layout_height="2dp" android:background="#2962FF" android:layout_alignStart="@+id/p2" android:layout_alignBottom="@+id/p2" android:rotation="3" android:transformPivotX="0dp"/>
                     <!-- Line 3-4 -->
                    <View android:layout_width="86dp" android:layout_height="2dp" android:background="#2962FF" android:layout_alignStart="@+id/p3" android:layout_alignBottom="@+id/p3" android:rotation="-18" android:transformPivotX="0dp"/>

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Individual Track Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                 android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Individual Track"
                    android:textColor="#0D1B2A"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAnalytics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/item_student_analytics"
                tools:itemCount="3"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
