<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">
        
        <ImageView
            android:id="@+id/imgMentorProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_profile"
            android:background="@drawable/bg_circle_translucent"
            android:backgroundTint="#FFFFFF"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            
            <TextView
                android:id="@+id/tvMentorRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACADEMIC ADVISOR"
                android:textColor="#1C52E6"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvMentorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prof. Rajesh Kumar"
                android:textColor="#0D1B2A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
            
            <TextView
                android:id="@+id/tvMentorDept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEPT. CSE"
                android:textColor="#9E9E9E"
                android:textSize="10sp"
                android:textStyle="bold"
                 android:letterSpacing="0.05"/>
        </LinearLayout>
        
        <TextView
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:text="ACTIVE"
             android:textColor="#FFFFFF"
             android:textSize="9sp"
             android:textStyle="bold"
             android:background="@drawable/bg_chip_blue"
             android:backgroundTint="#00C853"
             android:paddingHorizontal="8dp"
             android:paddingVertical="4dp"
             android:layout_marginStart="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
