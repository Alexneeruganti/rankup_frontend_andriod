<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#6200EA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivResultIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_check_circle"
            app:tint="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvResultStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXCELLENT!"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/tvScoreLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Score"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="32dp"/>

        <TextView
            android:id="@+id/tvFinalScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 / 3"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <ProgressBar
            android:id="@+id/progressScore"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="8dp"
            android:progress="100"
            android:progressTint="#00C853"
            android:layout_marginTop="24dp"
            android:backgroundTint="#33000000"/>

        <TextView
            android:id="@+id/tvFeedbackMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You have a strong command over communication. Keep it up!"
            android:textColor="#E0FFFFFF"
            android:textAlignment="center"
            android:textSize="16sp"
            android:layout_marginTop="32dp"
            android:lineSpacingExtra="4dp"/>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="BACK TO DASHBOARD"
            android:layout_marginTop="64dp"
            app:cornerRadius="16dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#6200EA"
            android:textStyle="bold"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
