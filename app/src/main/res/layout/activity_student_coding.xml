<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".StudentCodingActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1C52E6"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Coding Drills"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💎 120"
            android:textColor="#FFD600"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Difficulty & Generate Section -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout">
        
        <Spinner
            android:id="@+id/spinnerDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_edit_text_simple"
            android:entries="@array/difficulty_levels"
            android:paddingHorizontal="8dp"/>

        <Button
            android:id="@+id/btnGenerateQuestion"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="GENERATE NEW"
            android:textSize="10sp"
            android:backgroundTint="#6200EA"
            app:icon="@drawable/ic_bolt"
            style="@style/Widget.MaterialComponents.Button.Icon"/>

        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        
    </LinearLayout>

    <ScrollView
        android:id="@+id/questionScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="160dp"
        app:layout_constraintTop_toBottomOf="@+id/controlsLayout"
        app:layout_constraintBottom_toTopOf="@+id/editorSection"
        app:layout_constraintVertical_bias="0.0">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvQuestionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Difficulty &amp; Generate"
                android:textColor="#0D1B2A"
                android:textSize="18sp"
                android:textStyle="bold"/>
            
            <TextView
                android:id="@+id/tvQuestionDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Press the generate button to get a new AI-powered coding challenge."
                android:textColor="#424242"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Constraints"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:textColor="#0D1B2A"/>
            
             <TextView
                android:id="@+id/tvConstraints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textSize="12sp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Code Editor Section -->
    <LinearLayout
        android:id="@+id/editorSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#263238"
        app:layout_constraintTop_toBottomOf="@+id/questionScrollView"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#37474F"
            android:padding="8dp"
            android:gravity="center_vertical">
            
            <Spinner
                android:id="@+id/spinnerLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#FFFFFF"
                android:entries="@array/programming_languages"/>

            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>

            <Button
                android:id="@+id/btnRun"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="RUN CODE"
                android:backgroundTint="#00C853"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Code Editor Section -->
        <EditText
            android:id="@+id/etCodeEditor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@null"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:gravity="top|start"
            android:hint="// Write your source code here..."
            android:textColorHint="#90A4AE"
            android:inputType="textMultiLine|textNoSuggestions"
            android:scrollbars="vertical"/>

        <!-- Unified Console Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#000000"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom Input (Optional)"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etCustomInput"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="#1E272C"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="top|start"
                android:padding="6dp"
                android:hint="Leave blank to use question's sample test case..."
                android:textColorHint="#546E7A"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Output Console"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"/>
                
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="100dp">
                
                <TextView
                    android:id="@+id/tvOutput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#00E676"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:text="Ready to compile..."/>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
